# Normalize line endings. Store all text as LF in the repo so that running
# `node build.mjs` on Windows (core.autocrlf) no longer produces phantom
# whole-file diffs on the built HTML.
* text=auto eol=lf

*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.svg  text eol=lf
*.xml  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf

# Binary assets — never touch their bytes.
*.png  binary
*.jpg  binary
*.jpeg binary
*.woff2 binary
*.mp4  binary
*.ico  binary
